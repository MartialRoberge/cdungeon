# Copier ce fichier en .env et adapter les valeurs

# Clé secrète JWT — CHANGER en production
SECRET_KEY=cdungeon-super-secret-key-change-in-prod

# Durée de validité des tokens (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# URL de la base de données SQLite (chemin relatif au dossier backend/)
DATABASE_URL=sqlite:///./dungeon.db
